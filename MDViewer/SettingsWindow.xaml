<Window x:Class="it.carpanese.utilities.MDViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:it.carpanese.utilities.MDViewer"
        mc:Ignorable="d"
        Title="{local:Loc SettingsWindowTitle}" 
        Height="580" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        Icon="pack://application:,,,/MDViewer;component/Resources/md-viewer-icon.ico">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Contenuto scrollabile -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,10,24,10">
            <StackPanel>
                
                <!-- ========== AGGIORNAMENTI ========== -->
                <TextBlock Text="{local:Loc SettingsSectionUpdates}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <TextBlock Text="{local:Loc SettingsAutoUpdateLabel}" Style="{StaticResource SettingLabelTextStyle}"/>
                <ComboBox x:Name="CmbUpdateMode" Margin="0,4,0,0" Style="{StaticResource InputComboBoxStyle}">
                    <ComboBoxItem Content="{local:Loc SettingsUpdateModeManual}" Tag="Manual"/>
                    <ComboBoxItem Content="{local:Loc SettingsUpdateModeDaily}" Tag="Daily"/>
                    <ComboBoxItem Content="{local:Loc SettingsUpdateModeWeekly}" Tag="Weekly"/>
                </ComboBox>
                <TextBlock Text="{local:Loc SettingsAutoUpdateDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <!-- ========== RENDERING ========== -->
                <TextBlock Text="{local:Loc SettingsSectionRendering}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <TextBlock Text="{local:Loc SettingsDefaultProviderLabel}" Style="{StaticResource SettingLabelTextStyle}"/>
                <Button x:Name="BtnChooseDefaultProvider"
                        Margin="0,4,0,0"
                        Height="32"
                        Padding="10,4"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalContentAlignment="Left"
                        Click="BtnChooseDefaultProvider_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE946;"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtDefaultProvider" Margin="8,0,0,0"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{local:Loc SettingsDefaultProviderDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <CheckBox x:Name="ChkSyntaxHighlighting" Content="{local:Loc SettingsEnableSyntaxHighlighting}" 
                         Style="{StaticResource AppCheckBoxStyle}" Margin="0,8,0,0"/>
                <TextBlock Text="{local:Loc SettingsSyntaxHighlightingDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <!-- ========== TEMA ========== -->
                <TextBlock Text="{local:Loc SettingsSectionTheme}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <TextBlock Text="{local:Loc SettingsThemeLabel}" Style="{StaticResource SettingLabelTextStyle}"/>
                <ComboBox x:Name="CmbTheme" Margin="0,4,0,0" Style="{StaticResource InputComboBoxStyle}">
                    <ComboBoxItem Content="{local:Loc SettingsThemeSystem}" Tag="System"/>
                    <ComboBoxItem Content="{local:Loc SettingsThemeLight}" Tag="Light"/>
                    <ComboBoxItem Content="{local:Loc SettingsThemeDark}" Tag="Dark"/>
                </ComboBox>
                <TextBlock Text="{local:Loc SettingsThemeDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <!-- ========== FILE RECENTI ========== -->
                <TextBlock Text="{local:Loc SettingsSectionRecentFiles}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <TextBlock Text="{local:Loc SettingsMaxRecentFilesLabel}" Style="{StaticResource SettingLabelTextStyle}"/>
                <ComboBox x:Name="CmbMaxRecentFiles" Margin="0,4,0,0" Style="{StaticResource InputComboBoxStyle}">
                    <ComboBoxItem Content="{local:Loc SettingsRecentFilesOption5}" Tag="5"/>
                    <ComboBoxItem Content="{local:Loc SettingsRecentFilesOption10}" Tag="10"/>
                    <ComboBoxItem Content="{local:Loc SettingsRecentFilesOption15}" Tag="15"/>
                    <ComboBoxItem Content="{local:Loc SettingsRecentFilesOption20}" Tag="20"/>
                </ComboBox>
                <TextBlock Text="{local:Loc SettingsRecentFilesDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <Button x:Name="BtnClearRecentFiles" Content="{local:Loc SettingsClearRecentFilesButton}" 
                       Margin="0,4,0,0" Padding="12,6" HorizontalAlignment="Left"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="BtnClearRecentFiles_Click"/>
                
                <!-- ========== CACHE ========== -->
                <TextBlock Text="{local:Loc SettingsSectionCache}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="{local:Loc SettingsMaxCacheSizeLabel}" Style="{StaticResource SettingLabelTextStyle}"/>
                        <ComboBox x:Name="CmbCacheSize" Margin="0,4,0,0" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="25 MB" Tag="25"/>
                            <ComboBoxItem Content="50 MB" Tag="50"/>
                            <ComboBoxItem Content="100 MB" Tag="100"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="{local:Loc SettingsCacheDurationLabel}" Style="{StaticResource SettingLabelTextStyle}"/>
                        <ComboBox x:Name="CmbCacheDuration" Margin="0,4,0,0" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="{local:Loc SettingsCacheDuration1Day}" Tag="1"/>
                            <ComboBoxItem Content="{local:Loc SettingsCacheDuration7Days}" Tag="7"/>
                            <ComboBoxItem Content="{local:Loc SettingsCacheDuration30Days}" Tag="30"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="BtnClearCache" Content="{local:Loc SettingsClearCacheButton}" 
                           Padding="12,6" Style="{StaticResource SecondaryButtonStyle}" Click="BtnClearCache_Click"/>
                    <TextBlock x:Name="TxtCacheInfo" Style="{StaticResource SecondaryTextStyle}"
                              VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                
                <!-- ========== COMPORTAMENTO ========== -->
                <TextBlock Text="{local:Loc SettingsSectionBehavior}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <CheckBox x:Name="ChkAutoReload" Content="{local:Loc SettingsAutoReload}" 
                         Style="{StaticResource AppCheckBoxStyle}" Margin="0,4,0,0"/>
                <TextBlock Text="{local:Loc SettingsAutoReloadDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <CheckBox x:Name="ChkRememberPosition" Content="{local:Loc SettingsRememberWindowPosition}" 
                         Style="{StaticResource AppCheckBoxStyle}" Margin="0,4,0,0"/>
                <TextBlock Text="{local:Loc SettingsRememberWindowPositionDescription}" 
                          Style="{StaticResource SecondaryTextStyle}"/>
                
                <!-- ========== INFO ========== -->
                <TextBlock Text="{local:Loc SettingsSectionInfo}" Style="{StaticResource SectionHeaderTextStyle}"/>
                
                <TextBlock x:Name="TxtVersion" Style="{StaticResource SettingLabelTextStyle}"/>
                <Button x:Name="BtnGitHub" Content="{local:Loc SettingsOpenGitHubButton}" 
                       Margin="0,8,0,0" Padding="12,6" HorizontalAlignment="Left"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="BtnGitHub_Click"/>
                
                <Button x:Name="BtnResetDefaults" Content="{local:Loc SettingsResetDefaultsButton}" 
                       Margin="0,16,0,8" Padding="12,6" HorizontalAlignment="Left"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Click="BtnResetDefaults_Click"/>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Pulsanti in basso -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,1,1,0" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="{local:Loc SettingsCancelButton}" Width="80" Height="32" 
                       Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCancel_Click"/>
                <Button x:Name="BtnSave" Content="{local:Loc SettingsSaveButton}" Width="80" Height="32"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
