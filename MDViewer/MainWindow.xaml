<Window x:Class="it.carpanese.utilities.MDViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:it.carpanese.utilities.MDViewer"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:properties="clr-namespace:it.carpanese.utilities.MDViewer.Properties"
        Title="{Binding Source={x:Static properties:Resources.AppTitle}, StringFormat='MDViewer: {0}'}" Height="600" Width="800" 
        Icon="pack://application:,,,/MDViewer;component/Resources/md-viewer-icon.ico"
        Background="{DynamicResource WindowBackground}"
        AllowDrop="True" Drop="Window_Drop">
    <Window.Resources>
        <!-- Animazione rotazione per il loading spinner -->
        <Storyboard x:Key="SpinnerRotation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                           From="0" To="360" Duration="0:0:1"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Toolbar -->
        <Border Grid.Row="0"
                Margin="16,16,16,12"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,6">
        <Grid Height="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Pulsante Apri con icona folder -->
            <Button Grid.Column="0" x:Name="BtnApri" Click="OpenFile_Click" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,4,0" ToolTip="{x:Static properties:Resources.TooltipOpenFile}" Width="40" Height="32" Padding="0">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8E5;"
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <!-- Pulsante File Recenti con dropdown -->
            <Button Grid.Column="1" x:Name="BtnRecentFiles" Click="RecentFiles_Click"
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Margin="0,0,8,0" Width="30" Height="32"
                    ToolTip="{local:Loc MainRecentFilesTooltip}">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE70D;" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Button.ContextMenu>
                    <ContextMenu x:Name="RecentFilesMenu" Placement="Bottom">
                        <MenuItem Header="{local:Loc MainNoRecentFiles}" IsEnabled="False"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <TextBlock Grid.Column="2" Text="{x:Static properties:Resources.FileLabel}" VerticalAlignment="Center" 
                      Margin="8,0" FontWeight="Medium" Foreground="{DynamicResource TextForeground}"/>
            <TextBox Grid.Column="3" x:Name="FilePathBox" Margin="8,0" IsReadOnly="True"
                    Style="{StaticResource InputTextBoxStyle}"/>

            <!-- Pulsante selezione Provider -->
            <Button Grid.Column="4" x:Name="BtnSelectProvider" Click="SelectProvider_Click"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="8,0" Width="250" Height="32"
                    ToolTip="{local:Loc MainSelectProviderTooltip}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Text="&#xE946;"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtSelectedProvider" FontSize="12" Margin="6,0,0,0"
                              VerticalAlignment="Center" HorizontalAlignment="Center"
                              Text="{local:Loc MainProviderPlaceholder}"/>
                </StackPanel>
            </Button>

            <!-- Loading Spinner -->
            <Grid Grid.Column="5" x:Name="LoadingSpinner" Margin="8,0" Width="32" Height="32" Visibility="Collapsed">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE1CD;" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          Foreground="{DynamicResource SpinnerColor}">
                    <TextBlock.RenderTransform>
                        <RotateTransform CenterX="8" CenterY="8"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource SpinnerRotation}"/>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
            </Grid>

            <!-- Pulsante Stampa con icona printer -->
            <Button Grid.Column="6" x:Name="BtnStampa" Click="Print_Click" 
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Margin="8,0,4,0" ToolTip="{x:Static properties:Resources.TooltipPrint}" Width="40" Height="32"
                    IsEnabled="False">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE749;" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <!-- Pulsante Export PDF -->
            <Button Grid.Column="7" x:Name="BtnExportPdf" Click="ExportPdf_Click" 
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Margin="0,0,4,0" ToolTip="{local:Loc MainExportPdfTooltip}" Width="40" Height="32"
                    IsEnabled="False">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xEA90;" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <!-- Pulsante Ricarica con icona refresh -->
            <Button Grid.Column="8" x:Name="BtnRicarica" Click="Reload_Click" 
                    Style="{StaticResource ToolbarIconButtonStyle}"
                    Margin="0,0,0,0" ToolTip="{x:Static properties:Resources.TooltipReload}" Width="40" Height="32"
                    IsEnabled="False">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE72C;" 
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </Grid>
        </Border>

        <!-- Barra inferiore con info e aggiornamenti -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <!-- Immagine di sfondo con pack URI corretto -->
                <Image Source="pack://application:,,,/MDViewer;component/Resources/md-viewer-icon-512x512.png" 
                       Opacity="0.1" 
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MaxWidth="300"
                       MaxHeight="300"/>

            <!-- Messaggio di stato/errore -->
            <Border x:Name="StatusPanel" 
                    Background="{DynamicResource StatusWarningBackground}" 
                    BorderBrush="{DynamicResource StatusWarningBorder}" 
                    BorderThickness="1" CornerRadius="4" Padding="16" 
                    VerticalAlignment="Top" Margin="0,16,0,0" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusIcon" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                              Text="&#xE783;" Foreground="{DynamicResource StatusWarningForeground}" 
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusMessage" Text="{local:Loc LoadingMessage}" 
                              Foreground="{DynamicResource StatusWarningForeground}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- WebView2 per il contenuto Markdown -->
            <wv2:WebView2 x:Name="Viewer" />
            </Grid>

            <!-- Status bar inferiore -->
            <Border Grid.Row="1"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,8,0,0">
            <Grid Height="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Info versione -->
                <TextBlock Grid.Column="0" x:Name="VersionLabel" 
                          VerticalAlignment="Center" Margin="8,0"
                          FontSize="11" Foreground="{DynamicResource TextForegroundSecondary}"/>

                <!-- Pulsante Controlla aggiornamenti -->
                <Button Grid.Column="1" x:Name="BtnCheckUpdates" Click="CheckUpdates_Click"
                        Style="{StaticResource FlatActionButtonStyle}"
                        Margin="4,0" Padding="8,4"
                        ToolTip="{local:Loc MainCheckUpdatesTooltip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE895;" 
                                  VerticalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                        <TextBlock Text="{local:Loc MainUpdatesLabel}" FontSize="11" Margin="4,0,0,0"
                                  VerticalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                    </StackPanel>
                </Button>

                <!-- Pulsante Impostazioni -->
                <Button Grid.Column="2" x:Name="BtnSettings" Click="Settings_Click"
                        Style="{StaticResource FlatActionButtonStyle}"
                        Margin="4,0,8,0" Padding="8,4"
                        ToolTip="{local:Loc MainSettingsTooltip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE713;" 
                                  VerticalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                        <TextBlock Text="{local:Loc MainSettingsLabel}" FontSize="11" Margin="4,0,0,0"
                                  VerticalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                    </StackPanel>
                </Button>
            </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
